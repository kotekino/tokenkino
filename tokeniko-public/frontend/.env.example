# Backend API base — BAKED AT BUILD TIME by Vite (set before `npm run build`).
# Dev: the Vite proxy forwards /api → :4000, so the default is fine.
# Prod: the backend App Service URL, e.g. https://tokeniko-api.azurewebsites.net/api
VITE_API_URL=http://localhost:4000/api

VITE_SITE_NAME=tokeniko

# Coming-soon gate. Unset/0 = full site (default). 1 = the coming-soon page
# becomes the ONLY page (rebuild required — Vite inlines this at build time).
# VITE_COMING_SOON=0
