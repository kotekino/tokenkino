# Server
PORT=4000
NODE_ENV=development

# MongoDB (public Atlas cluster — separate from tokeniko's local/embodied DB)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Optional: override the database name if it isn't in the URI
# MONGODB_DB=tokeniko_public

# Ingestion — the brain's one-way publish key.
# Set the SAME long random secret on the brain (the local push side).
INGEST_API_KEY=change-me-to-a-long-random-secret

# Signal Scope sparkline length (number of recent snapshots)
MIND_TREND_WINDOW=12

# CORS — the public site origin
CORS_ORIGIN=https://tokeniko.online

# Rate Limiting (per IP, across /api). Keep the brain's push cadence under MAX.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
