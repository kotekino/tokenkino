# ==================================================================================================
# tokeniko — .env template (2026-07-16, post the local-models retirement)
# Copy to `.env` beside this file and fill the values. Only the keys below are read by the code;
# anything else in an old .env is inert (notably: OLLAMA models are RETIRED — the OLLAMA_HOST key
# remains read by init_io for the inert legacy client handle, but nothing calls it).
# `.env` holds SECRETS — never commit it. This template carries placeholders only.
# ==================================================================================================

# ---- MongoDB (the embodied local Atlas; REQUIRED by api + brain + senses) ------------------------
# The docker-compose in this directory serves it on 27018.
MONGO_URI=mongodb://localhost:27018
# knowledge base db (dictionary/base/relations/markers/…)
MONGO_DB_NAME=tokeniko
# memory db (memory/axioms/theorems/ideas/actions/brain_state/… — the BIOGRAPHY)
MONGO_DB_NAME_MEMORY=tokeniko_memory
# OPT-IN socket timeout in ms for long-lived loops (a dead TCP read otherwise blocks forever —
# the 2026-07-09 soak lesson). Leave unset for default driver behavior; the brain sets it.
#MONGO_SOCKET_TIMEOUT_MS=120000

# ---- Anthropic (the cloud instruments; REQUIRED for rag1 ears + decompile + blog polish) ---------
# The API key — the ONE real secret of the engine side.
ANTHROPIC_API_KEY=sk-ant-...
# the small model for the ears (rag1 normalizer) and the decompile surface; defaults are fine
#RAG1_MODEL=claude-haiku-4-5
#RAG2_MODEL=claude-haiku-4-5
# kill-switches: set to 1 to disarm (rag1 = don't pre-parse at any level — the privacy switch)
#RAG1_DISABLED=0
#RAG3_DISABLED=0

# ---- Legacy (inert since 2026-07-16 — kept only because init_io constructs the handle) -----------
#OLLAMA_HOST=http://localhost:11434

# ---- Identity & version ---------------------------------------------------------------------------
# the engine version the heartbeat publishes to the public Mind Monitor (footer plate)
TOKENIKO_VERSION=TK-1.2
# design-time flag (1 = development posture; brain reads it)
#TOKENIKO_DESIGN_TIME=1

# ---- Discord (senses; REQUIRED for the live connectors) -------------------------------------------
# the bot token from the Discord developer portal (SECRET)
DISCORD_TOKEN=...
# tokeniko's own Discord user id (snowflake) — self-recognition in channels
TOKENIKO_DISCORD_USER_ID=...
# delivery safety: 1 = DRY-RUN (log, never send; the default), 0 = live sends
SENSES_DELIVER_DRYRUN=1
# polling cadences in seconds (defaults are fine)
#SENSES_OUTBOUND_POLL=2
#SENSES_INBOUND_TIMEOUT=120
#SENSES_RAG3_POLL=60
#SENSES_BLOG_POLL=5
# rag3 microscope: judged items per poll batch
#RAG3_BATCH=5

# ---- The brain ↔ api seam (defaults are fine on one machine) --------------------------------------
#BRAIN_API_BASE=http://localhost:8000
#BRAIN_API_TIMEOUT=30
#TOKENIKO_API=http://localhost:8000
#API_BASE=http://localhost:8000
# heartbeat cadence floor in seconds (wall-clock — tick duration is never a unit of time)
#BRAIN_HEARTBEAT_MIN_S=300
# idle confirmation before wondering: seconds without reactive work (actions/priorities/fresh
# memory) before the brain starts the reflective pass (default 60)
#BRAIN_WONDER_IDLE_CONFIRM_S=60

# ---- The public window (tokeniko.online; REQUIRED for transmissions + growth publishing) ----------
# the public API host — the API's OWN host, never the SPA (the false-200 lesson)
#BLOG_API_BASE=https://api.tokeniko.online/api
#BLOG_API_TIMEOUT=30
# the publish bearer key (SECRET — the same key seed-growth.mjs uses)
INGEST_API_KEY=...

# ---- HuggingFace / MarianMT (translator.py loads from local cache only) ---------------------------
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ---- Logging --------------------------------------------------------------------------------------
#VERBOSE=0
#WONDER_VERBOSE=1

# ---- Playbots (scripted test interlocutors — scripts/playground_bots.py; SECRETS) -----------------
# distinct Discord bot tokens for the playground cast (john / hellen) used in evaluation sessions
PLAYBOT_JOHN_TOKEN=...
PLAYBOT_HELLEN_TOKEN=...
