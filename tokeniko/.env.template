# ==================================================================================================
# tokeniko — .env template (2026-07-16, post the local-models retirement)
# Copy to `.env` beside this file and fill the values. Only the keys below are read by the code;
# anything else in an old .env is inert (notably: OLLAMA models are RETIRED — the OLLAMA_HOST key
# remains read by init_io for the inert legacy client handle, but nothing calls it).
# `.env` holds SECRETS — never commit it. This template carries placeholders only.
# ==================================================================================================

# ---- MongoDB (the embodied local Atlas; REQUIRED by api + brain + senses) ------------------------
# The docker-compose in this directory serves it on 27018.
# directConnection=true is LOAD-BEARING: the single-node replica advertises its Docker-internal
# hostname (tk-atlas), which the host cannot always resolve — without the flag, driver topology
# discovery replaces localhost with tk-atlas and dies on DNS (observed live 2026-07-17). One
# body, one mongo: there is no cluster to discover.
MONGO_URI=mongodb://localhost:27018/?directConnection=true
# knowledge base db (dictionary/base/relations/markers/…)
MONGO_DB_NAME=tokeniko
# memory db (memory/axioms/theorems/ideas/actions/brain_state/… — the BIOGRAPHY)
MONGO_DB_NAME_MEMORY=tokeniko_memory
# OPT-IN socket timeout in ms for long-lived loops (a dead TCP read otherwise blocks forever —
# the 2026-07-09 soak lesson). Leave unset for default driver behavior; the brain sets it.
#MONGO_SOCKET_TIMEOUT_MS=120000

# ---- Anthropic (the cloud instruments; REQUIRED for rag1 ears + decompile + blog polish) ---------
# The API key — the ONE real secret of the engine side.
ANTHROPIC_API_KEY=sk-ant-...
# the small model for the ears (rag1 normalizer) and the decompile surface; defaults are fine
#RAG1_MODEL=claude-haiku-4-5
#RAG2_MODEL=claude-haiku-4-5
# kill-switches: set to 1 to disarm (rag1 = don't pre-parse at any level — the privacy switch)
#RAG1_DISABLED=0
#RAG3_DISABLED=0

# ---- Legacy (inert since 2026-07-16 — kept only because init_io constructs the handle) -----------
#OLLAMA_HOST=http://localhost:11434

# ---- Identity & version ---------------------------------------------------------------------------
# the engine version the heartbeat publishes to the public Mind Monitor (footer plate)
TOKENIKO_VERSION=TK-1.2
# design-time flag (1 = development posture; brain reads it)
#TOKENIKO_DESIGN_TIME=1

# ---- Discord (senses; REQUIRED for the live connectors) -------------------------------------------
# the bot token from the Discord developer portal (SECRET)
DISCORD_TOKEN=...
# tokeniko's own Discord user id (snowflake) — self-recognition in channels
TOKENIKO_DISCORD_USER_ID=...
# delivery safety: 1 = DRY-RUN (log, never send; the default), 0 = live sends
SENSES_DELIVER_DRYRUN=1
# polling cadences in seconds (defaults are fine)
#SENSES_OUTBOUND_POLL=2
#SENSES_INBOUND_TIMEOUT=120
#SENSES_RAG3_POLL=60
#SENSES_BLOG_POLL=5
# rag3 microscope: judged items per poll batch
#RAG3_BATCH=5

# ---- The brain ↔ api seam (defaults are fine on one machine) --------------------------------------
#BRAIN_API_BASE=http://localhost:8000
#BRAIN_API_TIMEOUT=30
#TOKENIKO_API=http://localhost:8000
#API_BASE=http://localhost:8000
# heartbeat cadence floor in seconds (wall-clock — tick duration is never a unit of time)
#BRAIN_HEARTBEAT_MIN_S=300
# idle confirmation before wondering: seconds without reactive work (actions/priorities/fresh
# memory) before the brain starts the reflective pass (default 60)
#BRAIN_WONDER_IDLE_CONFIRM_S=60

# ---- Compose 2.0 (the voice) -----------------------------------------------------------------------
# rag2-out — the outbound voice polish (senses): 1=off (the raw template text ships verbatim)
#RAG2_OUT_DISABLED=0
# replies shorter than this skip the polish (fragments are unverifiable anyway; default 25)
#SENSES_VOICE_POLISH_MIN_CHARS=25
# the anecdote (case 3) — the context ring + ideas-association knobs, all defaults conservative:
# the association proximity floor (a wrong side-note costs more than silence; default 0.6)
#ANECDOTE_FLOOR=0.6
# one side-note per channel per this many seconds (default 1800)
#ANECDOTE_COOLDOWN_S=1800
# the ambient directedness band that OPENS the side-note (below = someone else's thread ->
# polite silence; at/above the high bound = addressed talk -> he answers, never interjects)
#ANECDOTE_DIRECTEDNESS_LO=0.5
#ANECDOTE_DIRECTEDNESS_HI=0.9
# the per-channel context ring (a derivable RAM cache): rows kept / talk window seconds
#BRAIN_CONTEXT_RING_MAX=30
#BRAIN_CONTEXT_WINDOW_S=1800

# ---- The public window (tokeniko.online; REQUIRED for transmissions + growth publishing) ----------
# the public API host — the API's OWN host, never the SPA (the false-200 lesson)
#BLOG_API_BASE=https://api.tokeniko.online/api
#BLOG_API_TIMEOUT=30
# the publish bearer key (SECRET — the same key seed-growth.mjs uses)
INGEST_API_KEY=...

# ---- HuggingFace / MarianMT (translator.py loads from local cache only) ---------------------------
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ---- Logging --------------------------------------------------------------------------------------
#VERBOSE=0
#WONDER_VERBOSE=1

# ---- Playbots (scripted test interlocutors — scripts/playground_bots.py; SECRETS) -----------------
# distinct Discord bot tokens for the playground cast (john / hellen) used in evaluation sessions
PLAYBOT_JOHN_TOKEN=...
PLAYBOT_HELLEN_TOKEN=...

# ---- Bsky -----------------------------------------------------------------------------------------
BSKY_APP_PASSWORD=

# ---- The sleep phase (brain coordinator — §0 slice 3.5) -------------------------------------------
# He falls asleep WONDERING: confirmed idle + fruitless wondering for SLEEP_AFTER seconds -> sleep
# (the night's duty: ONE KB-change-gated untangle pass, retreats applied by the fork-D bar; the
# dream is told on waking). Any work wakes him; SLEEP_MAX ends the night regardless. While asleep
# the cooperative tick lengthens to SLEEP_TICK (the embodied machine rests).
#BRAIN_SLEEP_AFTER_S=600
#BRAIN_SLEEP_MAX_S=2700
#BRAIN_SLEEP_TICK_S=10

# ---- The voice (compose 2.0) ----------------------------------------------------------------------
# the agreement voice's RARITY dial (survey 2026-07-19): one outward nod per channel per window
# (seconds); within the window agreement dissolves back to silence-is-consent.
#AGREE_COOLDOWN_S=1800
# the goodnight's spam trap (survey slice 2): the falling-asleep farewell is spoken only into a
# channel someone used within this window (seconds) — goodnight is for people, not empty rooms.
#GOODNIGHT_RECENCY_S=3600
# the curiosity throttle (survey slice 3): one deepening «why» per TEACHER per window (seconds)
# — a teaching burst that mints five theorems earns one question, not five.
#ASK_COOLDOWN_S=600
# the etiquette throttle (survey slice 4): one greeting/welcome/farewell per SPEAKER per window
# (seconds) — etiquette without hello-loops.
#SOCIAL_COOLDOWN_S=3600
# the hypothesis engine (survey slice 5): a guess = charitable belief WITH EVIDENCE — the trust
# cap of a held hypothesis, and the zip-resemblance floor a claim must clear to be guessed at all.
#HYPOTHESIS_TRUST=0.3
#HYPOTHESIS_RESEMBLANCE_FLOOR=0.6
